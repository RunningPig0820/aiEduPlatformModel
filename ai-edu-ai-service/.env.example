# LLM API Keys (必须配置，不要提交此文件!)
# ============================================

# 智谱 AI (GLM 系列模型)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=填入你的智谱API_KEY

# DeepSeek
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=填入你的DeepSeek_API_KEY

# 阿里云百炼 (通义千问)
# 获取地址: https://bailian.console.aliyun.com/
# 注意: 需要 DashScope API Key
DASHSCOPE_API_KEY=填入你的DashScope_API_KEY
# 兼容旧配置名
BAILIAN_API_KEY=填入你的百炼_API_KEY


# 服务配置
# ============================================

# Java 后端调用 AI 服务的内部 Token
# 建议: 生成一个随机字符串
INTERNAL_TOKEN=your_internal_token_here

# 服务端口
PORT=8000

# 调试模式
DEBUG=false


# 可选配置
# ============================================

# 默认使用的 LLM Provider
DEFAULT_PROVIDER=zhipu

# 默认模型
DEFAULT_MODEL=glm-4-flash

# 日志级别
LOG_LEVEL=INFO