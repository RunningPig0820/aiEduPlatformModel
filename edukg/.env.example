# 课标知识点提取 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# 注意: 不要提交 .env 文件到 git!

# 百度 OCR API (收费服务)
# 获取地址: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=填入你的百度OCR_API_KEY
BAIDU_OCR_SECRET_KEY=填入你的百度OCR_SECRET_KEY

# 智谱 AI (免费模型 glm-4-flash)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=填入你的智谱API_KEY

# Neo4j 知识图谱配置
# ============================================
NEO4J_URI=bolt://your-neo4j-server:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password